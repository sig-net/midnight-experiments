{
  "name": "@midnight-experiments/serde-builtin-contract",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Feature experiment: pins the byte layout of Compact's builtin serialize<T,N>/deserialize<T,N> (natural-width little-endian fields, declaration order, right zero-padding) and proves an off-chain TypeScript encoder can byte-match it. Offline tests drive the compiled pure circuits in-process; the sibling integration-tests package proves the same under real zk. Run `yarn compile:zk` before deploying.",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "compile": "COMPACT_PATH=../../../node_modules compact compile --skip-zk src/serde-builtin.compact src/managed/serde-builtin",
    "compile:zk": "COMPACT_PATH=../../../node_modules compact compile src/serde-builtin.compact src/managed/serde-builtin",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@midnight-experiments/lib": "*",
    "@midnight-ntwrk/midnight-js": "5.0.0-beta.4",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "5.0.0-beta.4",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "5.0.0-beta.4",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "5.0.0-beta.4",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "5.0.0-beta.4",
    "@midnightntwrk/ledger-v9": "1.0.0-rc.3",
    "@sig-net/midnight-contract-deploy": "^0.0.4"
  },
  "devDependencies": {
    "@midnight-ntwrk/compact-runtime": "0.18.0-rc.1",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
